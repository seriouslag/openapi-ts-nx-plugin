{
  "name": "@seriouslag/source",
  "version": "0.0.0",
  "license": "MIT",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "nx run-many --target=build",
    "typecheck": "nx run-many --target=typecheck",
    "lint": "nx run-many --target=lint",
    "lint:fix": "nx run-many --target=lint -- --fix",
    "prepare": "lefthook install",
    "version:check:nx-plugin": "node ./packages/nx-plugin/scripts/version-with-openapi.mjs --check",
    "version:sync:nx-plugin": "node ./packages/nx-plugin/scripts/version-with-openapi.mjs --sync",
    "version:bump:nx-plugin": "node ./packages/nx-plugin/scripts/version-with-openapi.mjs --bump-patch",
    "test": "nx run-many --target=test",
    "publish": "nx run-many --target=publish"
  },
  "private": true,
  "dependencies": {
    "@nx/devkit": "^23.0.0",
    "nx": "^23.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nx/eslint": "^23.0.0",
    "@nx/js": "^23.0.0",
    "@nx/plugin": "^23.0.0",
    "@nx/react": "^23.0.0",
    "@nx/rollup": "^23.0.0",
    "@nx/vite": "^23.0.0",
    "@nx/vitest": "^23.0.0",
    "@nx/web": "^23.0.0",
    "@nx/workspace": "^23.0.0",
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.43",
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "eslint": "^10.5.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.4",
    "rollup": "^4.62.2",
    "tailwindcss": "^4.3.1",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
